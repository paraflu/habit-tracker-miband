{
  "package": "com.forlin.habittracker",
  "name": "Habit Tracker",
  "versionName": "1.0.0",
  "versionCode": 1,
  "minPlatformVersion": 1200,
  "icon": "/common/logo.png",
  "features": [
    { "name": "system.storage" },
    { "name": "system.vibrator" },
    { "name": "system.device" }
  ],
  "permissions": [
    { "origin": "*" }
  ],
  "config": {
    "logLevel": "log",
    "designWidth": 480
  },
  "router": {
    "entry": "pages/index",
    "pages": {
      "pages/index": {
        "component": "index"
      }
    }
  },
  "display": {
    "titleBar": false,
    "menu": false
  }
}
