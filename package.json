{
  "name": "habit-tracker-miband",
  "version": "1.0.0",
  "description": "Habit tracking app for Xiaomi Mi Band 10",
  "main": "src/app.ux",
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "commit": "commitlint --edit",
    "build": "hap-toolkit build",
    "build:release": "hap-toolkit build --disable-sign",
    "build:rpk": "bash ./build-rpk.sh"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@powerformer/vela-cli": "^0.0.16",
    "eslint": "^8.56.0",
    "hap-toolkit": "^2.0.8",
    "husky": "^9.0.0",
    "jest": "^29.7.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/__tests__",
      "<rootDir>/src"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/common/**/*.js",
      "!src/common/logo.png"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "text-summary",
      "lcov"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "lint-staged": {
    "src/**/*.{js,ux}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "xiaomi",
    "mi-band-10",
    "vela-js",
    "quick-app",
    "habit-tracker"
  ],
  "author": "@paraflu",
  "license": "MIT",
  "browserslist": [
    "chrome 65"
  ]
}