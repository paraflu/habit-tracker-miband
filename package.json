{
  "name": "habit-tracker-miband",
  "version": "1.0.0",
  "description": "Habit tracking app for Xiaomi Mi Band 10",
  "main": "src/app.ux",
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "commit": "commitlint --edit"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "eslint": "^8.56.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.2.0"
  },
  "lint-staged": {
    "src/**/*.{js,ux}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "keywords": [
    "xiaomi",
    "mi-band-10",
    "vela-js",
    "quick-app",
    "habit-tracker"
  ],
  "author": "@paraflu",
  "license": "MIT"
}
